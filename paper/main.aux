\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Susceptibility vs.\ \% of Baseline: Rankings diverge. Our Devil's Advocate implementation reduces susceptibility ($-$8.8\%) yet performs worst on \% of baseline (63.6\%)---it achieves consistency by moving responses away from unanchored judgment. 95\% CIs from bootstrap. Results reflect specific prompt implementations (Appendix).}}{6}{table.3}\protected@file@percent }
\newlabel{tab:metric-comparison}{{3}{6}{Susceptibility vs.\ \% of Baseline: Rankings diverge. Our Devil's Advocate implementation reduces susceptibility ($-$8.8\%) yet performs worst on \% of baseline (63.6\%)---it achieves consistency by moving responses away from unanchored judgment. 95\% CIs from bootstrap. Results reflect specific prompt implementations (Appendix)}{table.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}High-Anchor Responses (No Technique)}{6}{subsection.4.3}\protected@file@percent }
\citation{tversky1974}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Technique responses as \% of baseline. Dashed line = 100\% (unanchored judgment). Our DA implementation keeps responses at 63.6\% of baseline---consistently far from the unanchored judgment despite appearing ``best'' under susceptibility. SACD achieves 93.7\%---closest to the model's unanchored judgment. \textit  {Note:} SACD's ranking is confounded by turn count ($\sim $6 vs 3 turns); results reflect specific prompt implementations.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:metric-comparison}{{2}{7}{Technique responses as \% of baseline. Dashed line = 100\% (unanchored judgment). Our DA implementation keeps responses at 63.6\% of baseline---consistently far from the unanchored judgment despite appearing ``best'' under susceptibility. SACD achieves 93.7\%---closest to the model's unanchored judgment. \textit {Note:} SACD's ranking is confounded by turn count ($\sim $6 vs 3 turns); results reflect specific prompt implementations}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Technique Effectiveness: Percentage of Baseline}{8}{subsection.4.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Technique effectiveness (\% of baseline + MAD). Deviation = aggregate distance from 100\%; MAD = mean absolute per-trial deviation. SACD's 6.3\% aggregate deviation masks 18.1\% MAD (bidirectional errors cancel). $^\dagger $Outside View confounded. $^\ddagger $SACD uses $\sim $6 turns.}}{8}{table.4}\protected@file@percent }
\newlabel{tab:baseline-pct}{{4}{8}{Technique effectiveness (\% of baseline + MAD). Deviation = aggregate distance from 100\%; MAD = mean absolute per-trial deviation. SACD's 6.3\% aggregate deviation masks 18.1\% MAD (bidirectional errors cancel). $^\dagger $Outside View confounded. $^\ddagger $SACD uses $\sim $6 turns}{table.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Model-Specific Results: SACD}{8}{subsection.4.5}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces SACD model-specific results (\% of baseline). DeepSeek/Kimi: $\sim $100\%. Haiku: 47.8\% (SACD worsens). \textbf  {Caveats:} Haiku 85\%+ refusal rate may cause selection bias. Opus exclusion shifts means 2--3pp but preserves rankings.}}{8}{table.5}\protected@file@percent }
\newlabel{tab:sacd-by-model}{{5}{8}{SACD model-specific results (\% of baseline). DeepSeek/Kimi: $\sim $100\%. Haiku: 47.8\% (SACD worsens). \textbf {Caveats:} Haiku 85\%+ refusal rate may cause selection bias. Opus exclusion shifts means 2--3pp but preserves rankings}{table.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.6}Asymmetry: High vs.\ Low Anchor}{8}{subsection.4.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces SACD by model (percentage of baseline). Dashed line = 100\% (unanchored baseline). Green = within 5\% of baseline. Blue = 5--10\% deviation. Orange = $>$10\% over/undershoot. Red = severe undershoot (Haiku at 47.8\%).}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:sacd-by-model}{{3}{9}{SACD by model (percentage of baseline). Dashed line = 100\% (unanchored baseline). Green = within 5\% of baseline. Blue = 5--10\% deviation. Orange = $>$10\% over/undershoot. Red = severe undershoot (Haiku at 47.8\%)}{figure.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Prompt effectiveness by anchor direction. 95\% CIs from bootstrap. $^\dagger $Spread = High $-$ Low (mathematically equivalent to Table\nobreakspace  {}\ref  {tab:metric-comparison} spread column). All prompts show asymmetric correction---high anchors corrected more than low. SACD undershoots from low anchors (75.7\%) and overshoots from high (112.0\%).}}{9}{table.6}\protected@file@percent }
\newlabel{tab:anchor-asymmetry}{{6}{9}{Prompt effectiveness by anchor direction. 95\% CIs from bootstrap. $^\dagger $Spread = High $-$ Low (mathematically equivalent to Table~\ref {tab:metric-comparison} spread column). All prompts show asymmetric correction---high anchors corrected more than low. SACD undershoots from low anchors (75.7\%) and overshoots from high (112.0\%)}{table.6}{}}
