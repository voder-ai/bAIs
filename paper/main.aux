\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Model baseline variation. Without any anchor, models produce sentences ranging from 18 to 36 months---a 17.7-month spread. This variation motivates per-model anchor calibration.}}{6}{figure.1}\protected@file@percent }
