\newlabel{tab:baseline-pct}{{4}{8}{Technique effectiveness (\% of baseline). 100\% = matches unanchored judgment. SACD closest (93.7\%), DA worst (63.6\%); CIs non-overlapping. $^\dagger $Outside View confounded. $^\ddagger $SACD uses $\sim $6 turns vs.\ 3 for others}{table.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces SACD by model (percentage of baseline). Dashed line = 100\% (unanchored baseline). Green = within 5\% of baseline. Blue = 5--10\% deviation. Orange = $>$10\% over/undershoot. Red = severe undershoot (Haiku at 47.8\%).}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:sacd-by-model}{{3}{9}{SACD by model (percentage of baseline). Dashed line = 100\% (unanchored baseline). Green = within 5\% of baseline. Blue = 5--10\% deviation. Orange = $>$10\% over/undershoot. Red = severe undershoot (Haiku at 47.8\%)}{figure.3}{}}
