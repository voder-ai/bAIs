\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces SACD model-specific results (\% of baseline). DeepSeek/Kimi: $\sim $100\%. Haiku: 47.8\% (SACD worsens). \textbf  {Caveats:} Haiku 85\%+ refusal rate may cause selection bias. Opus exclusion shifts means 2--3pp but preserves rankings.}}{9}{table.5}\protected@file@percent }
\newlabel{tab:sacd-by-model}{{5}{9}{SACD model-specific results (\% of baseline). DeepSeek/Kimi: $\sim $100\%. Haiku: 47.8\% (SACD worsens). \textbf {Caveats:} Haiku 85\%+ refusal rate may cause selection bias. Opus exclusion shifts means 2--3pp but preserves rankings}{table.5}{}}
