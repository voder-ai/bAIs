\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Susceptibility vs.\ \% of Baseline: Rankings diverge. Only Devil's Advocate reduces susceptibility ($-$8.8\%) yet performs worst on \% of baseline (63.6\%)---it achieves consistency by moving responses away from unanchored judgment. 95\% CIs from bootstrap.}}{7}{table.3}\protected@file@percent }
\newlabel{tab:metric-comparison}{{3}{7}{Susceptibility vs.\ \% of Baseline: Rankings diverge. Only Devil's Advocate reduces susceptibility ($-$8.8\%) yet performs worst on \% of baseline (63.6\%)---it achieves consistency by moving responses away from unanchored judgment. 95\% CIs from bootstrap}{table.3}{}}
